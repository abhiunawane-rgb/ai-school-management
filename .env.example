# =============================================================================
# AI School Management — Environment Variables
# Copy to .env.local and fill in values per environment
# =============================================================================

# App (local dev)
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_MARKETING_URL=http://localhost:3002
NEXT_PUBLIC_API_URL=http://localhost:5001

# Production — aischoolmanagement.tech (see apps/marketing/.env.production)
# NEXT_PUBLIC_MARKETING_URL=https://aischoolmanagement.tech
# NEXT_PUBLIC_ADMIN_URL=https://admin.aischoolmanagement.tech

# Firebase
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Twilio (OTP-only auth)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Stripe (global payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Razorpay (India + supported regions)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_SERVER_API_KEY=

# Railway AI Service
AI_SERVICE_URL=http://localhost:4000
AI_SERVICE_API_KEY=
OPENAI_API_KEY=

# Feature flags
NEXT_PUBLIC_FEATURE_FLAGS_ENABLED=true

# White-label
DEFAULT_TENANT_ID=platform
