{
  "name": "ai-school-management",
  "version": "1.0.0",
  "private": true,
  "description": "Global AI-powered school management SaaS platform",
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean --continue",
    "dev": "turbo run dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File ./scripts/dev-clean.ps1",
    "dev:web": "turbo run dev --filter=@ai-school/marketing --filter=@ai-school/admin",
    "build:bigrock": "powershell -ExecutionPolicy Bypass -File ./scripts/build-bigrock-all.ps1",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "firebase:deploy": "firebase deploy --only firestore:rules,firestore:indexes,storage,functions",
    "firebase:emulators": "firebase emulators:start"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
